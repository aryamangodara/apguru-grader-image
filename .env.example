# ---- Environment ----
# ENV=PROD
ENV=STAG

# ---- App Settings ----
APP_NAME="APGuru Grader API"
DEBUG=False
API_PREFIX="/api/v1"
LOG_LEVEL=INFO

# ---- MySQL Database (active connection) ----
DB_HOST=your_database_host
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

# ---- Local Database (dev override) ----
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_USER=root
LOCAL_DB_PASSWORD=your_local_password
LOCAL_DB_NAME=your_local_db_name
LOCAL_DB_PORT=3306
USE_LOCAL_DB=true

# ---- Gemini / Grader LLM ----
# The grader's Gemini client reads GEMINI_API_KEY from the environment, or uses
# Vertex AI when a service account is configured (see Google Cloud / Vertex AI).
GEMINI_API_KEY=your_gemini_api_key

# ---- Google Cloud / Vertex AI ----
# In Docker the key is mounted at /app/vertex-key.json (see docker-compose.yml), so
# point GOOGLE_APPLICATION_CREDENTIALS at that container path. Omit it entirely if
# you attach the service account to the EC2 instance role (ADC).
# GOOGLE_APPLICATION_CREDENTIALS=/app/vertex-key.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global

# ---- AP FRQ Grader ----
# The /grader endpoints are intentionally PUBLIC (no JWT) in every environment.
# Restrict them at the edge (ALB / Nginx / WAF / security group); the PDF fetch is
# SSRF-guarded in app/services/grader/url_guard.py.
# Route the grader's Gemini calls through Vertex AI even when GEMINI_API_KEY is
# set. The handwriting-OCR call runs ~150s, which returns 504 DEADLINE_EXCEEDED
# on AI Studio's tighter server-side deadline but completes on Vertex. Honoured
# only when the Vertex service account above is configured AND its key file
# exists; otherwise the grader falls back to GEMINI_API_KEY.
GRADER_USE_VERTEX=true
# Post-grading audience summaries (student / teacher / parent, issue #14). On by
# default; set false to skip the extra Gemini call per grade.
GRADER_ENABLE_SUMMARIES=true
# GRADER_SUMMARIES_MODEL=gemini-3.5-flash

# ---- Langfuse Observability (optional) ----
# Leave both keys blank to disable tracing (app keeps working; no data sent).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Gunicorn (optional override) ----
# GUNICORN_WORKERS=2
# Recycle each worker after this many requests (+ jitter) to bound memory growth;
# pairs with the 1 GiB container mem_limit in docker-compose.yml.
# GUNICORN_MAX_REQUESTS=200
# GUNICORN_MAX_REQUESTS_JITTER=50

# ---- Deployment (Docker) ----
# Interface the grader container binds to on the host. Defaults to 127.0.0.1
# (localhost only, fronted by the host's reverse proxy — the secure default).
# Set to 0.0.0.0 to publish the API directly on all interfaces (plain HTTP, no
# TLS). Only do that if you ALSO restrict access at the security group / WAF —
# the endpoints are public (no auth) and return student PII.
# GRADER_BIND_IP=127.0.0.1
# Host port the grader container binds to. Keep in sync with the GRADER_HOST_PORT
# Actions variable (the deploy workflow defaults to 8081 when that variable is unset).
GRADER_HOST_PORT=8081
